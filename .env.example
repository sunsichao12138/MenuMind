# ═══════════════════════════════════════
# Zenith Culinaria - Environment Variables
# ═══════════════════════════════════════

# Supabase Configuration
# Get these from your Supabase project: Settings > API
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Frontend Supabase (prefix with VITE_ for Vite)
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# Volcengine Ark (Doubao AI) Configuration
ARK_API_KEY="your-ark-api-key"
ARK_MODEL_ID="your-model-endpoint-id"
ARK_API_ENDPOINT="https://ark.cn-beijing.volces.com/api/v3/chat/completions"

# Server port (optional, defaults to 3001)
SERVER_PORT=3001
